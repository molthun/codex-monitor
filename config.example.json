{
  "installRoot": "C:\\CodexMonitor",
  "rainmeter": {
    "skinPath": "",
    "executable": "C:\\Program Files\\Rainmeter\\Rainmeter.exe",
    "skinName": "CodexMonitor",
    "skinFile": "CodexMonitor.ini",
    "desktopMode": {
      "alwaysOnTop": -2,
      "draggable": 0,
      "clickThrough": 1,
      "savePosition": 0,
      "autoSelectScreen": 0
    }
  },
  "bridge": {
    "taskName": "CodexMonitor Bridge Elevated",
    "mutexName": "CodexMonitorHardwareBridge",
    "outputFile": "C:\\CodexMonitor\\@Resources\\temps.txt",
    "updateSeconds": 1,
    "boardFanIdentifierPrefix": "/lpc/nct6796dr/fan/"
  },
  "display": {
    "followPrimary": true,
    "marginRight": 24,
    "marginTop": 24,
    "watchIntervalSeconds": 5,
    "autoProfileHeightThreshold": 1440,
    "autoUpdate": true
  },
  "profiles": {
    "auto": true,
    "default": "Auto",
    "compact": "1080p",
    "large": "4K"
  },
  "disks": [
    "C:",
    "D:",
    "E:"
  ],
  "network": {
    "ignoreAdaptersContaining": [
      "hyper-v",
      "virtual switch",
      "virtual switch extension",
      "virtual filtering platform",
      "wsl",
      "teredo",
      "teredo tunneling",
      "wan miniport",
      "qos packet scheduler",
      "wfp native mac layer",
      "wfp 802.3 mac layer",
      "lightweight filter",
      "native wifi filter driver",
      "virtual wifi filter driver",
      "pseudo-interface",
      "vswitch",
      "vethernet",
      "bluetooth"
    ],
    "wifiApNamesContaining": [
      "wi-fi direct",
      "wifi direct",
      "hotspot"
    ],
    "wifiNamesContaining": [
      "wi-fi",
      "wifi",
      "wireless",
      "wlan",
      "беспровод"
    ],
    "ethernetNamesContaining": [
      "ethernet",
      "intel"
    ]
  },
  "startup": {
    "watcherShortcutName": "CodexMonitor Display Watcher.lnk"
  }
}
